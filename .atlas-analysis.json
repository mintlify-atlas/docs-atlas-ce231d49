  "keyFeatures": [
    "Multi-kiosk management from a single admin dashboard",
    "Drag-and-drop playlist editor with image and video support",
    "Bulk media upload with automatic file organization per kiosk",
    "Fullscreen kiosk player with looping playlist playback",
    "Built-in media tools: Video-to-GIF conversion, video compression, and PDF-to-images",
    "SQLite-backed storage with no external database required",
    "Production-ready with Nginx reverse proxy and PM2 process management",
    "Firefox kiosk mode support for dedicated display screens"
  ],
  "publicApiSurface": [
